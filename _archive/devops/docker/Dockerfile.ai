# Production Dockerfile for TiranaFly AI Service
FROM python:3.11-slim as builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir xgboost lightgbm scikit-learn pandas numpy shap torch --index-url https://download.pytorch.org/whl/cpu

COPY . .

FROM python:3.11-slim

WORKDIR /app

COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin
COPY . .

RUN useradd -m tiranafly && chown -R tiranafly:tiranafly /app
USER tiranafly

EXPOSE 8001

CMD ["uvicorn", "ai.inference_service:app", "--host", "0.0.0.0", "--port", "8001", "--workers", "2"]
